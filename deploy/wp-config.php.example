<?php
/**
 * wp-config.php template for DirectAdmin hosting deployment.
 *
 * INSTRUCTIONS:
 * 1. Copy this file to your WordPress root as wp-config.php
 * 2. Fill in all PLACEHOLDER values below with real values
 * 3. Generate AUTH keys from: https://api.wordpress.org/secret-key/1.1/salt/
 * 4. Never commit wp-config.php to version control (it's in .gitignore)
 *
 * @package WordPress
 */

// ─── Database settings ───────────────────────────────────────────────────────
// Get these from your DirectAdmin → MySQL Databases panel.

define( 'DB_NAME',     'YOUR_DB_NAME' );       // e.g. username_wpbinh
define( 'DB_USER',     'YOUR_DB_USER' );       // e.g. username_wpuser
define( 'DB_PASSWORD', 'YOUR_DB_PASSWORD' );   // Strong random password
define( 'DB_HOST',     'localhost' );           // Usually 'localhost' on DirectAdmin
define( 'DB_CHARSET',  'utf8mb4' );
define( 'DB_COLLATE',  'utf8mb4_unicode_ci' );

// ─── Table prefix ─────────────────────────────────────────────────────────────
// Change this if using a non-standard prefix (security best practice)
$table_prefix = 'wp_';

// ─── Authentication Keys and Salts ───────────────────────────────────────────
// IMPORTANT: Generate fresh keys from https://api.wordpress.org/secret-key/1.1/salt/
// and replace all 8 lines below.

define( 'AUTH_KEY',         'put your unique phrase here' );
define( 'SECURE_AUTH_KEY',  'put your unique phrase here' );
define( 'LOGGED_IN_KEY',    'put your unique phrase here' );
define( 'NONCE_KEY',        'put your unique phrase here' );
define( 'AUTH_SALT',        'put your unique phrase here' );
define( 'SECURE_AUTH_SALT', 'put your unique phrase here' );
define( 'LOGGED_IN_SALT',   'put your unique phrase here' );
define( 'NONCE_SALT',       'put your unique phrase here' );

// ─── WordPress environment ────────────────────────────────────────────────────

// Set to 'true' only during development — never in production
define( 'WP_DEBUG',         false );
define( 'WP_DEBUG_LOG',     false );
define( 'WP_DEBUG_DISPLAY', false );

// Disable the file editor in wp-admin (security)
define( 'DISALLOW_FILE_EDIT', true );

// WordPress memory limit — increase if needed
define( 'WP_MEMORY_LIMIT', '256M' );
define( 'WP_MAX_MEMORY_LIMIT', '512M' );

// Limit post revisions to save database space
define( 'WP_POST_REVISIONS', 3 );

// Auto-save interval
define( 'AUTOSAVE_INTERVAL', 120 );

// ─── Site URLs ────────────────────────────────────────────────────────────────
// Only uncomment if you have URL issues on DirectAdmin
// define( 'WP_HOME',    'https://yourdomain.com' );
// define( 'WP_SITEURL', 'https://yourdomain.com' );

// ─── File system method (DirectAdmin / cPanel shared hosting) ────────────────
define( 'FS_METHOD', 'direct' );

// ─── HTTPS / SSL ──────────────────────────────────────────────────────────────
// Uncomment if your site is behind a load balancer / reverse proxy
// define( 'FORCE_SSL_ADMIN', true );
// if ( isset($_SERVER['HTTP_X_FORWARDED_PROTO']) && $_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https' ) {
//     $_SERVER['HTTPS'] = 'on';
// }

// ─── WooCommerce / PHP settings ───────────────────────────────────────────────
// These are set at PHP level — also add to .htaccess or php.ini if needed
@ini_set( 'upload_max_filesize', '64M' );
@ini_set( 'post_max_size',       '64M' );
@ini_set( 'max_execution_time',  '300' );

// ─── Absolute path ────────────────────────────────────────────────────────────
if ( ! defined( 'ABSPATH' ) ) {
    define( 'ABSPATH', __DIR__ . '/' );
}

require_once ABSPATH . 'wp-settings.php';
